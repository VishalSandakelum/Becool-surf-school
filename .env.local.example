# ─── SMTP (contact form) ────────────────────────────────────────────────────
# Use the credentials from your business email host (e.g. Hostinger, Zoho,
# Office365). See docs/SMTP_SETUP.md for help finding these values.
SMTP_HOST=smtp.your-host.com
SMTP_PORT=465
SMTP_SECURE=true                   # true for port 465 (SSL), false for 587 (STARTTLS)
SMTP_USER=info@becoolsrilanka.com
SMTP_PASSWORD=replace-with-your-mailbox-password

# Where the form submissions are sent. Leave blank to use SMTP_USER.
CONTACT_TO_EMAIL=info@becoolsrilanka.com
# What the visitor sees as the From: address on the confirmation email.
CONTACT_FROM_EMAIL=info@becoolsrilanka.com
CONTACT_FROM_NAME=Be Cool Surf School

# ─── Google Reviews (Places API) ────────────────────────────────────────────
# See docs/GOOGLE_REVIEWS_SETUP.md for step-by-step instructions on getting
# both of these values. Both are required to fetch live reviews; if either is
# missing the page falls back to data/reviews-fallback.json.
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACE_ID=

# ─── Public site URL (used in canonical / OG / sitemap) ────────────────────
NEXT_PUBLIC_SITE_URL=https://becoolsrilanka.com
